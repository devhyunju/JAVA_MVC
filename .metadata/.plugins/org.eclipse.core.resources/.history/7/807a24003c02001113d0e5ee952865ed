package com.global.json;

public class User {
	private String name; 
	private int age; 
	private boolean isDeveloper; 
	
	//기본 생성자 (필수)
	public User() {
		
	}
	//생성자, Getter, Setter
	public User(String name, int age, boolean isDeveloper) {
		this.name = name; 
		this.age = age; 
		this.isDeveloper = this.isDeveloper;
	}
	public String getName() { return name; }
	public int getAge() { return age; }
	public boolean getisDeveloper() { return isDeveloper; }
}
